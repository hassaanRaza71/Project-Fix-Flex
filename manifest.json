{
  "manifest_version": 3,
  "name": "Fix the Flex",
  "version": "2.0",
  "description": "Calculates live percentage and GPA from your fast university portal's uploaded marks.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://flexstudent.nu.edu.pk/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://flexstudent.nu.edu.pk/Student/Transcript*"],
      "js": ["transcript.js"],
      "run_at": "document_idle"
    },
    {
  "matches": ["https://flexstudent.nu.edu.pk/Student/StudentMarks*"],
  "js": ["creditsSync.js", "content.js"],
  "css": ["style.css"],
  "run_at": "document_idle"
    },
    {
  "matches": ["https://flexstudent.nu.edu.pk/Student/StudentAttendance*"],
  "js": ["creditsSync.js", "attendance.js"],
  "run_at": "document_idle"
    }
  ]
}
